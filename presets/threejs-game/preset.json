{
  "type": "threejs-game",
  "name": "Three.js Game",
  "description": "Browser-based 3D game with Three.js",
  "default_tech_stack": "Three.js, TypeScript, Vite",
  "directories": [
    "src",
    "src/scenes",
    "src/objects",
    "src/systems",
    "src/utils",
    "public",
    "public/assets",
