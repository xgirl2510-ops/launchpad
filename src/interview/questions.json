{
  "language_rule": "Questions are written in English. Detect the user's language from their first message and translate all questions, hints, and titles when presenting to the user.",
  "phases": [
    {
      "id": "basics",
      "title": "Basic information",
      "questions": [
        {
          "id": "project_name",
          "question": "Project name?",
          "type": "text",
          "required": true
        },
        {
          "id": "project_type",
          "question": "Project type?",
          "type": "select",
          "options": ["unity-game", "threejs-game", "saas-web", "api-service", "custom"],
          "option_descriptions": {
            "unity-game": "2D/3D game built with Unity engine",
            "threejs-game": "Browser-based 3D game or interactive experience",
            "saas-web": "Web app with user accounts, dashboard, billing",
            "api-service": "Backend API, microservice, or data pipeline",
            "custom": "Other project type, you choose everything"
          },
          "required": true
        },
        {
          "id": "project_stage",
          "question": "Project stage?",
          "type": "select",
          "options": ["new", "maintenance"],
          "option_descriptions": {
            "new": "Starting from scratch",
            "maintenance": "Existing project, adding features or fixing"
          },
          "required": true
        },
        {
          "id": "project_scale",
          "question": "Project scale?",
          "type": "select",
          "options": ["playground", "poc", "pilot", "mvp", "production"],
          "option_descriptions": {
            "playground": "Sandbox, learning, experimentation",
            "poc": "Proof of concept, validate an idea",
            "pilot": "Limited release, testing with real users",
            "mvp": "Minimum viable product, core features only",
            "production": "Full production, complete feature set"
          },
          "required": true,
          "condition": "project_stage == new"
        },
        {
          "id": "description",
          "question": "Brief project description?",
          "type": "text",
          "required": true,
          "hint": "e.g. 'A 2D roguelike with turn-based combat' or 'SaaS dashboard for tracking fitness goals'"
        },
        {
          "id": "repo_status",
          "question": "Create new repo or use existing?",
          "type": "select",
          "options": ["new", "existing"],
          "required": true
        },
        {
          "id": "repo_url",
          "question": "Repo URL (if existing)?",
          "type": "text",
          "condition": "repo_status == existing"
        },
        {
          "id": "repo_visibility",
          "question": "Repo visibility?",
          "type": "select",
          "options": ["public", "private"],
          "required": true
        }
      ]
    },
    {
      "id": "tech_stack",
      "title": "Tech stack details",
      "questions": [
        {
          "id": "primary_language",
          "question": "Primary programming language?",
          "type": "text",
          "required": true,
          "hint": "e.g. C#, TypeScript, Python, Rust, Go"
        },
        {
          "id": "framework",
          "question": "Main framework or engine?",
          "type": "text",
          "required": true,
          "hint": "e.g. Unity 2022, Next.js 15, FastAPI, Express"
        },
        {
          "id": "database",
          "question": "Database (if any)?",
          "type": "text",
          "hint": "e.g. PostgreSQL, MongoDB, Supabase, Firebase"
        },
        {
          "id": "additional_tools",
          "question": "Other key libraries or tools?",
          "type": "text",
          "hint": "e.g. Prisma, TailwindCSS, Redis, Docker"
        },
        {
          "id": "code_style",
          "question": "Preferred code style or conventions?",
          "type": "text",
          "hint": "e.g. Airbnb style, Google style, Microsoft C# conventions, or 'auto' to generate from best practices"
        }
      ]
    },
    {
      "id": "team",
      "title": "Team configuration",
      "questions": [
{
          "id": "features",
          "question": "Which features to enable?",
          "type": "multi-select",
          "options": [
            {"value": "ccpm", "label": "CCPM", "description": "Quản lý ticket qua GitHub"},
            {"value": "mempalace", "label": "MemPalace", "description": "Tăng cường bộ nhớ cho AI"}
          ],
          "default": ["ccpm", "mempalace"]
        }
      ]
    },
    {
      "id": "extras",
      "title": "Customization",
      "questions": [
        {
          "id": "additional_skills",
          "question": "Any additional skills to install?",
          "type": "review-and-add",
          "source": "preset:skills.json",
          "hint": "Review preset skills, then add extras if needed"
        },
        {
          "id": "additional_agents",
          "question": "Any additional agents to create?",
          "type": "review-and-add",
          "source": "preset:agents.json",
          "hint": "Review preset agents, then add extras if needed"
        }
      ]
    }
  ]
}
